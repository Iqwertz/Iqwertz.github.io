---
const events = [
  {
    commit: "a41c2de",
    date: "Sept 2013",
    branch: "academic",
    title: "AHS Wiedner Gymnasium",
    detail: "High School & Matura graduation",
  },
  {
    commit: "c0ffeeb",
    date: "Oct 2019",
    branch: "work",
    title: "Intern @ CERN",
    detail: "Portable configurator for network switches at the LHCb",
  },
  {
    commit: "b00b1e5",
    date: "Aug 2020",
    branch: "work",
    title: "Intern @ Web & Söhne",
    detail: "Full-stack development passing workflows with Angular & Express.js",
  },
  {
    commit: "1a2b3c4",
    date: "Apr 2021",
    branch: "freelance",
    title: "Self Employed Dev",
    detail: "Fullstack SW dev offering Angular, Firebase, Node.js, MVP development & 3D printing",
  },
  {
    commit: "d3adb3f",
    date: "Aug 2021",
    branch: "work",
    title: "Intern @ Web & Söhne",
    detail: "Second term: tackling more extensive application architecture",
  },
  {
    commit: "8f7e6d5",
    date: "Sept 2021",
    branch: "extra",
