    ],
  },
  {
    commit: "b00b1e5",
    date: "Aug 2020 & Aug 2021",
    branch: "life",
    track: "life",
    coloredAs: "work",
    trackOpen: true,
    title: "Intern @ Web & Söhne",
    detail:
      "Learned to develop professional web applications using Angular and Express.js gaining hands-on experience in full-stack development | Got insight into how a software companies manage big teams and workloads",
    highlights: [
      "Built full-stack features with Angular and Express.js",
      "Collaborated in larger team and delivery workflows",
    ],
  },
  {
    commit: "1a2b3c4",
    date: "Apr 2021",
    branch: "freelance",
    track: "freelance",
    trackOpen: true,
    title: "Self Employed Dev",
    detail: "Fullstack SW dev, MVP development & 3D printing",
    highlights: ["Built MVPs for early-stage ideas", "Delivered custom full-stack solutions"],
    projects: [{ label: "Project portfolio", href: "/projects" }],
  },
