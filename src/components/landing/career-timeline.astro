    date: "Aug 2025 - Present",
    branch: "academic",
    track: "uni",
    trackOpen: true,
    title: "MSc. Condensed Matter Physics",
    detail: "Technical University of Munich",
    highlights: ["Specializing in condensed matter physics"],
  },
