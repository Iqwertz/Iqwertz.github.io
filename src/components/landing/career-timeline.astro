const branches = [
  { id: "life", color: "#06b6d4", label: "Life", isOpen: true }, // Vibrant Cyan
  { id: "academic", color: "#a855f7", label: "Academic", isOpen: true }, // Violet Purple
  { id: "work", color: "#10b981", label: "Employment", isOpen: true }, // Emerald Green
  { id: "freelance", color: "#f43f5e", label: "Freelance", isOpen: true }, // Rose Pink
  { id: "extra", color: "#f59e0b", label: "Extracurricular", isOpen: true }, // Amber
];

const timelineData = JSON.stringify({
  events: events.map((e) => ({
    commit: e.commit,
    branch: e.branch,
    track: e.track,
    trackOpen: e.trackOpen,
    coloredAs: e.coloredAs,
    mergeBefore: e.mergeBefore,
    branchFromTrack: e.branchFromTrack,
  })),
  branches: branches.map((b) => ({ id: b.id, color: b.color, isOpen: b.isOpen })),
});
---

<section id="career" class="career-timeline-section">
  <div class="title">
    <h2>Career</h2>
  </div>

  <div class="git-timeline-container">
    <div class="git-header">
      <div class="mac-buttons"><span></span><span></span><span></span></div>
      <h2><span class="prompt">julius@earth:~$</span> git log --graph --oneline --all</h2>
    </div>

    <div class="git-canvas">
      <div class="git-legend">
        {
          branches.map((b) => (
            <span class="legend-item" style={`--b-color: ${b.color}`}>
              <span class="dot" /> {b.label}
            </span>
          ))
        }
      </div>

      <git-timeline data-timeline={timelineData} class="git-graph-wrapper">
        <div id="svg-container" class="svg-container" style="opacity: 0;">
          <svg class="git-svg"></svg>
        </div>

        <div id="content-container" class="content-container">
          {
            events.map((event, rowIndex) => {
              const eventBranch = branches.find((b) => b.id === event.branch);
              const coloredBranch = event.coloredAs ? branches.find((b) => b.id === event.coloredAs) : eventBranch;
              const isExpandable =
                (event.highlights && event.highlights.length > 0) || (event.projects && event.projects.length > 0);

              return (
                <div
                  class={`git-row group ${isExpandable ? "is-expandable" : ""}`}
                  data-row-index={rowIndex}
                  data-commit={event.commit}
                  data-highlights={JSON.stringify(event.highlights ?? [])}
                  data-projects={JSON.stringify(event.projects ?? [])}
                  data-scroll-animate="fadeInRight"
                  style={`animation-delay: ${rowIndex * 0.1}s;`}
                >
                  <div class="git-content" style={`--branch-color: ${coloredBranch?.color};`}>
                    <div class="content-header">
                      <span class="commit-hash">{event.commit}</span>
                      <span class="commit-date">({event.date})</span>
                      <span
                        class="commit-ref"
                        style={`color: ${coloredBranch?.color}; border-color: ${coloredBranch?.color};`}
                      >
                        {coloredBranch?.label}
                      </span>
                      {isExpandable && (
                        <span class="expand-indicator" title="Click to expand details">
                          <svg
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          >
                            <polyline points="6 9 12 15 18 9" />
                          </svg>
                        </span>
                      )}
                    </div>
                    <div class="commit-message">
                      <h3 class="message-title" style={`color: ${coloredBranch?.color}`}>
                        {event.title}
                      </h3>
                      {event.detail && <p class="message-detail">{event.detail}</p>}
                    </div>

                    {isExpandable && (
                      <div class="terminal-wrapper">
                        <div class="terminal-wrapper-inner">
                          <div class="terminal-container">
                            <div class="terminal-body">
                              <div class="terminal-prompt">
                                <span class="prompt-symbol" style={`color: ${coloredBranch?.color};`}>
                                  $
                                </span>
                                <span class="terminal-command" />
                              </div>
                              <div class="terminal-output" />
                            </div>
                          </div>
                        </div>
                      </div>
                    )}
                  </div>
                </div>
              );
            })
          }
        </div>
      </git-timeline>
    </div>
  </div>
</section>

<style lang="scss">
  .career-timeline-section {
    .title {
      text-align: center;

      h2 {
        color: var(--accent);
        font-weight: 400;
      }
    }
  }

  .git-timeline-container {
    max-width: 900px;
    margin: 4rem auto;
    background-color: #0f172a;
    border-radius: 12px;
    border: 1px solid #1e293b;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    //box-shadow: 15px 15px 0 var(--accent);
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, "Liberation Mono", monospace;
    overflow: hidden;
    color: #e2e8f0;

    .git-header {
      background-color: #0b0f19;
      padding: 1rem 1.5rem;
      border-bottom: 1px solid #1e293b;
      display: flex;
      align-items: center;
      gap: 1.5rem;

      .mac-buttons {
        display: flex;
        gap: 8px;
        span {
          width: 12px;
          height: 12px;
          border-radius: 50%;
          &:nth-child(1) {
            background-color: #f43f5e;
          }
          &:nth-child(2) {
            background-color: #f59e0b;
          }
          &:nth-child(3) {
            background-color: #10b981;
          }
        }
      }

      h2 {
        margin: 0;
        font-size: 0.95rem;
        font-weight: normal;
        color: #cbd5e1;

        .prompt {
          color: #06b6d4;
          font-weight: bold;
          margin-right: 8px;
        }
      }
    }
  }

  .git-canvas {
    padding: 2rem 1.5rem;
  }

  .git-legend {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    font-size: 0.85rem;
    padding: 0.5rem 1rem;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.05);

    .legend-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--b-color);
      font-weight: 600;
      letter-spacing: 0.5px;

      .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background-color: var(--b-color);
      }
    }
  }

  .git-graph-wrapper {
    display: flex;
    position: relative;
    margin-top: 1rem;
    gap: 1rem;

    .svg-container {
      width: 110px;
      flex-shrink: 0;
      position: relative;

      .git-svg {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        overflow: visible;
      }
    }

    .content-container {
      flex-grow: 1;
      display: flex;
      flex-direction: column;
      min-width: 0; /* Important for flex children to allow text wrapping inside */
    }
  }

  .git-row {
    position: relative;
    padding-bottom: 1.45rem;
    transition: background-color 0.2s ease;
    border-radius: 8px;
    padding-left: 8px;

    &.is-expandable .git-content {
      cursor: pointer;
    }

    &:last-child {
      padding-bottom: 0;
    }
    &:hover {
      background-color: rgba(255, 255, 255, 0.03);
    }
  }

  .git-content {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: 0.35rem 0.8rem;
    margin-left: 0.25rem;
    z-index: 4;
    min-width: 0;

    .content-header {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 0.35rem;
      flex-wrap: wrap;

      .commit-hash {
        color: #facc15;
        font-size: 0.8rem;
      }
      .commit-date {
        color: #94a3b8;
        font-size: 0.78rem;
      }

      .commit-ref {
        font-size: 0.7rem;
        padding: 2px 10px;
        border: 1px solid;
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.05);
        font-weight: bold;
        letter-spacing: 0.5px;
      }

      .expand-indicator {
        margin-left: auto;
        color: #64748b;
        display: flex;
        align-items: center;
        transition:
          transform 0.3s ease,
          color 0.2s ease;
      }
    }

    .commit-message {
      .message-title {
        margin: 0 0 0.25rem 0;
        font-size: 1rem;
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
        font-weight: 600;
        letter-spacing: 0.3px;
      }

      .message-detail {
        margin: 0.15rem 0 0;
        color: #94a3b8;
        font-size: 0.88rem;
        line-height: 1.45;
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
        white-space: normal;
        overflow-wrap: break-word; /* Ensure detail text wraps properly on mobile */
      }
    }
  }

  /* Interaction and State */
  .git-row:hover .expand-indicator {
    color: var(--branch-color);
  }
  .git-row.is-open .expand-indicator {
    transform: rotate(180deg);
    color: var(--branch-color);
  }

  /* Terminal Expansion Animation */
  .terminal-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .terminal-wrapper-inner {
    overflow: hidden;
  }
  .git-row.is-open .terminal-wrapper {
    grid-template-rows: 1fr;
  }

  .terminal-container {
    width: 0%;
    opacity: 0;
    margin-top: 0.85rem;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: #020617#fff;
    transition:
      width 0.35s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.2s ease;
    overflow: hidden; /* Avoid nowrap which blocks mobile, use hidden to restrict horizontal growth */
    cursor: default;
  }

  .git-row.is-open .terminal-container {
    width: 100%;
    opacity: 1;
  }

  .terminal-body {
    padding: 0.85rem;
    font-size: 0.84rem;
    width: 100%;
    box-sizing: border-box;
  }

  .terminal-prompt {
    display: flex;
    align-items: flex-start; /* Better alignment on mobile */
    gap: 0.5rem;
    color: #e2e8f0;

    .prompt-symbol {
      font-weight: bold;
      flex-shrink: 0;
    }

    .terminal-command {
      word-break: break-all;
    }
  }

  .terminal-output {
    opacity: 0;
    transform: translateY(-4px);
    margin-top: 0.65rem;
    color: #cbd5e1;
    white-space: normal;

    &.is-visible {
      opacity: 1;
      transform: translateY(0);
      transition:
        opacity 0.2s ease,
        transform 0.2s ease;
    }
  }

  :global(.detail-list),
  :global(.projects-list) {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  :global(.detail-list li),
  :global(.projects-list li) {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    margin-bottom: 0.35rem;
    line-height: 1.5;
  }
  :global(.bullet) {
    color: var(--branch-color);
    flex-shrink: 0; /* Prevent bullet squishing on mobile */
  }

  :global(.project-links) {
    margin-top: 0.85rem;
    padding-top: 0.65rem;
    border-top: 1px dashed rgba(255, 255, 255, 0.1);
  }
  :global(.project-title) {
    color: #94a3b8;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.45rem;
  }
  :global(.projects-list a) {
    color: #38bdf8;
    text-decoration: none;
    transition: text-decoration 0.2s ease;
  }
  :global(.projects-list a:hover) {
    text-decoration: underline;
  }

  .typing-caret::after {
    content: "▋";
    color: var(--branch-color);
    margin-left: 4px;
    animation: caretBlink 0.9s steps(1) infinite;
  }

  @keyframes caretBlink {
    50% {
      opacity: 0;
    }
  }

  /* Compact Mobile Layout */
  @media screen and (max-width: 600px) {
    .git-timeline-container {
      margin: 2rem 0.5rem;
    }
    .git-header {
      padding: 0.85rem 1rem;
      gap: 1rem;
    }
    .git-header h2 {
      font-size: 0.8rem !important;
    }
    .git-canvas {
      padding: 1rem 0.5rem;
    }
    .git-legend {
      gap: 0.75rem;
      padding: 0.4rem 0.6rem;
      margin-bottom: 1.5rem;
    }
    .git-graph-wrapper {
      gap: 0.5rem;
    }
    .git-graph-wrapper .svg-container {
      width: 75px; /* Dynamically adjusted for scaled-down branches */
    }
    .git-row {
      padding-left: 0;
    }
    .git-content {
      padding: 0.25rem;
      margin-left: 0;
    }
    .content-header {
      gap: 4px;
    }
    .content-header .commit-hash,
    .content-header .commit-date {
      font-size: 0.7rem;
    }
    .commit-ref {
      font-size: 0.65rem;
      padding: 2px 6px;
    }
    .terminal-body {
      padding: 0.65rem;
    }
  }

  .svg-container {
    transition: opacity 0.2s ease-in;
  }

  @keyframes graphWipeDown {
    0% {
      clip-path: inset(0 -50% 100% -50%);
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    100% {
      clip-path: inset(0 -50% -10% -50%);
      opacity: 1;
    }
  }

  :global(.animate__wipeDown) {
    animation-name: graphWipeDown !important;
    animation-duration: 2s !important;
    animation-timing-function: ease-in-out !important;
    animation-fill-mode: forwards !important;
  }
</style>

<script>
  class GitTimeline extends HTMLElement {
    resizeObserver: ResizeObserver;
    typingTimers: number[];

    constructor() {
      super();
      this.resizeObserver = new ResizeObserver(() => this.draw());
      this.typingTimers = [];
    }

    connectedCallback() {
      this.resizeObserver.observe(this);
      setTimeout(() => this.draw(), 50);

      const svgContainer = this.querySelector(".svg-container") as HTMLElement;
      if (svgContainer) {
        const observer = new IntersectionObserver(
          (entries) => {
            if (entries[0].isIntersecting) {
              svgContainer.style.opacity = "1";
              svgContainer.classList.add("animate__animated", "animate__wipeDown");
              observer.disconnect();
            }
          },
          { rootMargin: "0px 0px -50% 0px", threshold: 0 },
        );
        observer.observe(this);
      }

      this.addEventListener("click", (event) => {
        const target = event.target as HTMLElement;

        // Ensure links are clickable without toggling the row
        if (target.tagName === "A") return;

        // Avoid triggering click if text is being selected
        const selection = window.getSelection();
        if (selection && selection.toString().length > 0) return;

        const row = target.closest(".git-row.is-expandable") as HTMLElement | null;
        if (!row) return;

        const isInsideTerminal = target.closest(".terminal-container") !== null;
        const isOpen = row.classList.contains("is-open");

        // Allow interacting/selecting inside terminal without closing
        // Clicking on the rest of the row (header, title, detail) will close it
        if (isOpen && isInsideTerminal) return;

        if (isOpen) {
          this.closeReveal(row);
        } else {
          this.openReveal(row);
        }
      });
    }

    disconnectedCallback() {
      this.resizeObserver.disconnect();
      this.clearTypingTimers();
    }

    clearTypingTimers() {
      this.typingTimers.forEach((timer) => window.clearTimeout(timer));
      this.typingTimers = [];
    }

    closeReveal(row: HTMLElement) {
      this.clearTypingTimers();
      row.classList.remove("is-open");

      const command = row.querySelector(".terminal-command") as HTMLElement | null;
      const output = row.querySelector(".terminal-output") as HTMLElement | null;

      if (command) {
        command.textContent = "";
        command.classList.remove("typing-caret");
      }
      if (output) {
        output.innerHTML = "";
        output.classList.remove("is-visible");
      }
    }

    openReveal(row: HTMLElement) {
      this.clearTypingTimers();

      // Automatically close previously opened rows (Accordion behaviour)
      this.querySelectorAll(".git-row.is-open").forEach((openedRow) => {
        if (openedRow !== row) this.closeReveal(openedRow as HTMLElement);
      });

      const commit = row.dataset.commit ?? "";
      const highlights = JSON.parse(row.dataset.highlights ?? "[]") as string[];
      const projects = JSON.parse(row.dataset.projects ?? "[]") as Array<{ label: string; href: string }>;

      row.classList.add("is-open");

      const command = row.querySelector(".terminal-command") as HTMLElement | null;
      const output = row.querySelector(".terminal-output") as HTMLElement | null;

      if (!command || !output) return;

      command.classList.add("typing-caret");
      command.textContent = "";
      output.innerHTML = "";
      output.classList.remove("is-visible");

      // Give the CSS width transition some time to sweep out before typing begins (300ms)
      const initTimer = window.setTimeout(() => {
        const fullCommand = `git show ${commit} --details`;
        const chars = Array.from(fullCommand);

        const typeCommand = (index: number) => {
          command.textContent = chars.slice(0, index).join("");

          if (index < chars.length) {
            const timer = window.setTimeout(() => typeCommand(index + 1), 16);
            this.typingTimers.push(timer);
            return;
          }

          command.classList.remove("typing-caret");
          const renderTimer = window.setTimeout(() => {
            this.renderOutput(output, highlights, projects);
          }, 100);
          this.typingTimers.push(renderTimer);
        };

        typeCommand(1);
      }, 350);

      this.typingTimers.push(initTimer);
    }

    renderOutput(output: HTMLElement, highlights: string[], projects: Array<{ label: string; href: string }>) {
      let html = "";

      if (highlights.length) {
        html += `<ul class="detail-list">`;
        highlights.forEach((item) => {
          html += `<li><span class="bullet">→</span> <span>${item}</span></li>`;
        });
        html += `</ul>`;
      }

      if (projects.length) {
        html += `<div class="project-links">`;
        html += `<div class="project-title">Related Projects:</div>`;
        html += `<ul class="projects-list">`;
        projects.forEach((project) => {
          html += `<li><span class="bullet">↳</span> <a href="${project.href}">${project.label}</a></li>`;
        });
        html += `</ul>`;
        html += `</div>`;
      }

      output.innerHTML = html;
      output.classList.add("is-visible");
    }

    draw() {
      const dataStr = this.dataset.timeline;
      if (!dataStr) return;

      const { events, branches } = JSON.parse(dataStr);
      const svg = this.querySelector(".git-svg");
      const container = this.querySelector(".svg-container");

      if (!svg || !container) return;
      const containerRect = container.getBoundingClientRect();
      if (containerRect.height === 0 || containerRect.width === 0) return;

      // Adjust spacing and elements based on screen width
      const isMobile = window.innerWidth <= 600;
      const colWidth = isMobile ? 14 : 20;
      const offsetLeft = isMobile ? 10 : 14;
      const strokeW = isMobile ? 2 : 3;
      const rOut = isMobile ? 6 : 8;
      const rIn = isMobile ? 4 : 5;

      const rows = Array.from(this.querySelectorAll(".git-row"));

      const nodeCoords = rows
        .map((row: any, i) => {
          const header = row.querySelector(".content-header");
          if (!header) return null;

          let nodeY = row.offsetTop + header.offsetTop + header.offsetHeight / 2;
          const branchIndex = branches.findIndex((b: any) => b.id === events[i].branch);
          const nodeX = offsetLeft + branchIndex * colWidth;

          return {
            x: nodeX,
            y: nodeY,
            color: events[i].coloredAs
              ? branches.find((b: any) => b.id === events[i].coloredAs).color
              : branches[branchIndex].color,
            branch: events[i].branch,
            track: events[i].track,
            idx: i,
          };
        })
        .filter(Boolean);

      let svgContent = "";

      const getTrackX = (trackId: string) => {
        const ev = events.find((e: any) => e.track === trackId);
        if (!ev) return offsetLeft;
        const bIdx = branches.findIndex((b: any) => b.id === ev.branch);
        return offsetLeft + bIdx * colWidth;
      };

      const tracks = Array.from(new Set(events.map((e: any) => e.track)));

      tracks.forEach((trackId: any) => {
        const bEvents = nodeCoords.filter((n: any) => n.track === trackId);
        if (bEvents.length === 0) return;

        const firstEvent = bEvents[0];
        const rawFirst = events[firstEvent!.idx];
        const b = branches.find((br: any) => br.id === firstEvent!.branch);

        for (let i = 0; i < bEvents.length - 1; i++) {
          const p1 = bEvents[i];
          const p2 = bEvents[i + 1];
          svgContent += `<path d="M ${p1!.x} ${p1!.y} L ${p2!.x} ${p2!.y}" fill="none" stroke="${b.color}" stroke-width="${strokeW}"  />`;
        }

        if (trackId !== "life") {
          const parentTrackId = rawFirst.branchFromTrack || "life";
          const parentX = getTrackX(parentTrackId);

          const curveEndY = firstEvent!.y;
          const curveOffset = isMobile ? 15 : 25;
          const curveStartY = Math.max(0, curveEndY - curveOffset * 2);

          svgContent += `
            <path d="
              M ${parentX} ${curveStartY}
              C ${parentX} ${curveStartY + curveOffset}, ${firstEvent!.x} ${curveEndY - curveOffset}, ${firstEvent!.x} ${curveEndY}
            " fill="none" stroke="${b.color}" stroke-width="${strokeW}"  />
          `;
        }

        const lastEvent = bEvents[bEvents.length - 1];
        const rawLast = events[lastEvent!.idx];

        if (!rawLast.trackOpen) {
          const targetTrackId = "life";
          const targetX = getTrackX(targetTrackId);

          let mergeY = lastEvent!.y + 50;

          if (rawLast.mergeBefore) {
            const targetNode = nodeCoords.find((n: any) => events[n.idx].commit === rawLast.mergeBefore);
            if (targetNode) {
              mergeY = targetNode.y - (isMobile ? 15 : 25);
            }
          }

          const curveStartY = Math.max(lastEvent!.y, mergeY - 50);
          const cp1Y = curveStartY + (mergeY - curveStartY) / 2;
          const cp2Y = mergeY - (mergeY - curveStartY) / 2;

          svgContent += `
            <path d="
              M ${lastEvent!.x} ${lastEvent!.y}
              L ${lastEvent!.x} ${curveStartY}
              C ${lastEvent!.x} ${cp1Y}, ${targetX} ${cp2Y}, ${targetX} ${mergeY}
            " fill="none" stroke="${b.color}" stroke-width="${strokeW}" opacity="0.6" />
          `;
        } else {
          const strokeDashAttr = trackId === "life" ? "" : 'stroke-dasharray="6 6"';

          svgContent += `
            <path d="M ${lastEvent!.x} ${lastEvent!.y} L ${lastEvent!.x} ${containerRect.height + 40}"
                  fill="none" stroke="${b.color}" stroke-width="${strokeW}" ${strokeDashAttr} opacity="0.8" />
          `;
        }
      });

      nodeCoords.forEach((node: any) => {
        svgContent += `<line x1="${node.x + rOut}" y1="${node.y}" x2="100%" y2="${node.y}"
                         stroke="${node.color}" stroke-width="2" opacity="0.2" stroke-dasharray="4 3"/>`;

        svgContent += `<circle cx="${node.x}" cy="${node.y}" r="${rOut}" fill="#0f172a" stroke="none" />`;

        svgContent += `<circle cx="${node.x}" cy="${node.y}" r="${rIn}" fill="#0f172a" stroke="${node.color}" stroke-width="${strokeW}"
                         style="transition: all 0.2s ease; transform-origin: ${node.x}px ${node.y}px; "
                         onmouseover="this.setAttribute('r', '${rIn + 2}')"
                         onmouseout="this.setAttribute('r', '${rIn}')" />`;
      });

      svg.innerHTML = svgContent;
    }
  }

  if (!customElements.get("git-timeline")) {
    customElements.define("git-timeline", GitTimeline);
  }
</script>
