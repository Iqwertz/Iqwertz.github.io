---
const events = [
  {
    commit: "init   ",
    date: "2003",
    branch: "life",
    track: "life",
    trackOpen: true,
    title: "Vienna, Austria",
    detail: "Born and raised",
  },
  {
    commit: "a41c2de",
    date: "Sept 2013 - June 2021",
    branch: "academic",
    track: "highschool",
    trackOpen: true,
    title: "AHS Wiedner Gymnasium",
    detail: "Graduated with Honors, Focus on natural sciences & mathematics",
  },
  {
    commit: "c0ffeeb",
    date: "Oct 2019",
    branch: "academic",
    track: "highschool",
    trackOpen: false,
    mergeBefore: "e55c192",
    title: "Intern @ CERN",
    detail:
      "HSSIP Program: Worked on a portable configurator for network switches at the LHCb, Learned about the different detectors at CERN and what it takes to run a particle collider",
    highlights: [
