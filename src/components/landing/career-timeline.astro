    date: "Oct 2023 - Present",
    branch: "extra",
    track: "extra",
    trackOpen: true,
    title: "Board Member @ 'Ein Zuhause für Bukarester Straßenkinder'",
    detail:
      "Joined the charity as a board member, helping to organize fundraising events and manage the charity's online presence",
    highlights: ["Co-organized fundraising initiatives", "Maintained and improved the charity’s online presence"],
  },
  {
    commit: "7fc2901",
    date: "June 2024",
    branch: "work",
    track: "linque",
    trackOpen: true,
    branchFromTrack: "uni",
