    date: "Aug 2022 - Aug 2025",
    branch: "academic",
    track: "uni",
    trackOpen: true,
    title: "B.Sc. Physics",
    detail: "Technical University of Munich",
    highlights: ["Built strong analytical and quantitative foundation"],
  },
  {
