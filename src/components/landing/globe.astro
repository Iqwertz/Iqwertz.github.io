---

---

<div class="globe-section" id="travels">
  <h2>Where I've Been</h2>
  <p>Exploring the world, one line of code at a time.</p>
  <div class="globe-container">
    <canvas id="cobe-canvas"></canvas>
  </div>
</div>

<style>
  .globe-section {
    padding: 2em;
    text-align: center;
    max-width: 1000px;
    margin: 0 auto;
    color: var(--text-color, #c1c2c5);
  }

  .globe-section h2 {
    font-size: 2.5em;
    margin-bottom: 0.2em;
    color: #027c68;
  }

  .globe-section p {
    font-size: 1.1em;
    margin-bottom: 2em;
    opacity: 0.8;
  }

  .globe-container {
    width: 100%;
    max-width: 600px;
    aspect-ratio: 1 / 1;
    margin: 0 auto;
    position: relative;
    /* Added subtle blur/glow behind the globe to make it pop */
    border-radius: 50%;
  }

  #cobe-canvas {
    width: 100%;
    height: 100%;
    cursor: grab;
  }

  #cobe-canvas:active {
    cursor: grabbing;
  }
</style>

<script>
  import createGlobe from "cobe";

  const canvas = document.getElementById("cobe-canvas") as HTMLCanvasElement;

  if (canvas) {
    let phi = 0;
    let width = 0;
    let currentPhi = 0;
    let currentTheta = 0;
    let isDragging = false;
    let startX = 0;
    let autoRotationSpeed = 0.003;

    const onResize = () => {
      if (canvas.parentElement) {
        width = canvas.parentElement.offsetWidth;
      }
    };
    window.addEventListener("resize", onResize);
    onResize();

    // Mouse drag handling
    canvas.addEventListener("mousedown", (e) => {
      isDragging = true;
      startX = e.clientX;
    });

    window.addEventListener("mouseup", () => {
      isDragging = false;
    });

    window.addEventListener("mousemove", (e) => {
      if (isDragging) {
        const delta = e.clientX - startX;
        phi -= delta * 0.005; // Drag direction
        startX = e.clientX;
      }
    });

    // Touch handling for mobile
    canvas.addEventListener("touchstart", (e) => {
      isDragging = true;
      startX = e.touches[0].clientX;
    });

    window.addEventListener("touchend", () => {
      isDragging = false;
    });

    window.addEventListener("touchmove", (e) => {
      if (isDragging) {
        const delta = e.touches[0].clientX - startX;
        phi -= delta * 0.005;
        startX = e.touches[0].clientX;
      }
    });

    // A slightly dark/minimal base color scheme
    const globe = createGlobe(canvas, {
      devicePixelRatio: 2,
      width: width * 2,
      height: width * 2,
      phi: 0,
      theta: 0.3,
      dark: 1, // Dark mode aesthetic
      diffuse: 1.2,
      mapSamples: 16000,
      mapBrightness: 6,
      baseColor: [0.1, 0.1, 0.1],
      // Accent color matching #027c68
      markerColor: [2 / 255, 124 / 255, 104 / 255],
      glowColor: [0.05, 0.05, 0.05],
      markers: [
        { location: [48.2082, 16.3738], size: 0.06 }, // Vienna / Europe
        { location: [35.6762, 139.6503], size: 0.08 }, // Tokyo
        { location: [40.7128, -74.006], size: 0.06 }, // New York
        { location: [-33.8688, 151.2093], size: 0.07 }, // Sydney
        { location: [-22.9068, -43.1729], size: 0.06 }, // Rio de Janeiro
        { location: [-33.9249, 18.4241], size: 0.06 }, // Cape Town
      ],
      onRender: (state) => {
        // Handle resizing dynamically
        state.width = width * 2;
        state.height = width * 2;

        // Auto rotation when not dragging
        if (!isDragging) {
          phi += autoRotationSpeed;
        }
        state.phi = phi;
      },
    });
  }
</script>
