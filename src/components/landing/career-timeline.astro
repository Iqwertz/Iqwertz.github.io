---
const events = [
  {
    commit: "init   ",
    date: "Sept 2013",
    branch: "life",
    track: "life",
    trackOpen: true,
    title: "The Journey Begins",
    detail: "Vienna, Austria",
  },
  {
    commit: "a41c2de",
    date: "Sept 2013 - June 2021",
    branch: "academic",
    track: "highschool",
    trackOpen: true,
    title: "AHS Wiedner Gymnasium",
    detail: "Started High School",
  },
  {
    commit: "c0ffeeb",
    date: "Oct 2019",
    branch: "academic",
    track: "highschool",
    trackOpen: false,
    mergeBefore: "e55c192", // Beautifully merges back right before Civilian Service (Visually ~Summer 2021)
    title: "Intern @ CERN",
    detail: "Portable configurator for network switches at the LHCb",
  },
  {
    commit: "b00b1e5",
    date: "Aug 2020",
    branch: "life",
    track: "life",
    coloredAs: "work",
    trackOpen: true,
    title: "Intern @ Web & Söhne",
    detail: "Full-stack development passing workflows with Angular & Express.js",
  },
  {
    commit: "1a2b3c4",
    date: "Apr 2021",
    branch: "freelance",
    track: "freelance",
    trackOpen: true,
    title: "Self Employed Dev",
    detail: "Fullstack SW dev, MVP development & 3D printing",
  },
  {
    commit: "e55c192",
    date: "Nov 2021 - Aug 2022",
    branch: "work",
    track: "civ",
    trackOpen: false,
    mergeBefore: "90a1b2c", // Merges back before Relocating to Munich
    title: "Civilian Servant",
    detail: "everyone codes: managed UX-Design course & agile team management",
  },
  {
    commit: "90a1b2c",
    date: "Aug 2022",
    branch: "life",
    track: "life",
    trackOpen: true,
    title: "Relocating to Munich",
    detail: "Started academic path at Technical University of Munich",
  },
  {
    commit: "8b9c0d1",
    date: "Aug 2022 - Aug 2025",
    branch: "academic",
    track: "uni",
    trackOpen: true,
    title: "BSc. Physics",
    detail: "Technical University of Munich",
  },
  {
    commit: "7fc2901",
    date: "June 2024",
    branch: "work",
    track: "linque",
    trackOpen: true,
    branchFromTrack: "uni", // Branches smoothly out of the 'uni' track timeline
    title: "Working Student @ Linque",
    detail: "Developing Python software & FPGA designs",
  },
  {
    commit: "4b92def",
    date: "Aug 2025 - Present",
    branch: "academic",
    track: "uni",
    trackOpen: true,
    title: "MSc. Condensed Matter Physics",
    detail: "Technical University of Munich",
  },
];

const branches = [
  { id: "life", color: "#06b6d4", label: "Life", isOpen: true }, // Vibrant Cyan
  { id: "academic", color: "#a855f7", label: "Academic", isOpen: true }, // Violet Purple
  { id: "work", color: "#10b981", label: "Employment", isOpen: true }, // Emerald Green
  { id: "freelance", color: "#f43f5e", label: "Freelance", isOpen: true }, // Rose Pink
  { id: "extra", color: "#f59e0b", label: "Extracurricular", isOpen: true }, // Amber
];

const timelineData = JSON.stringify({
  events: events.map((e) => ({
    commit: e.commit,
    branch: e.branch,
    track: e.track,
    trackOpen: e.trackOpen,
    coloredAs: e.coloredAs,
    mergeBefore: e.mergeBefore,
    branchFromTrack: e.branchFromTrack,
  })),
  branches: branches.map((b) => ({ id: b.id, color: b.color, isOpen: b.isOpen })),
});
---

<section id="career" class="git-timeline-container">
  <div class="git-header">
    <div class="mac-buttons"><span></span><span></span><span></span></div>
    <h2><span class="prompt">julius@workspace:~$</span> git log --graph --oneline --all</h2>
  </div>

  <div class="git-canvas">
    <div class="git-legend">
      {
        branches.map((b) => (
          <span class="legend-item" style={`--b-color: ${b.color}`}>
            <span class="dot" /> {b.label}
          </span>
        ))
      }
    </div>

    <git-timeline data-timeline={timelineData} class="git-graph-wrapper">
      <div id="svg-container" class="svg-container" style="opacity: 0;">
        <svg class="git-svg"></svg>
      </div>

      <div id="content-container" class="content-container">
        {
          events.map((event, rowIndex) => {
            const eventBranch = branches.find((b) => b.id === event.branch);
            const coloredBranch = event.coloredAs ? branches.find((b) => b.id === event.coloredAs) : eventBranch;

            return (
              <div
                class="git-row group"
                data-row-index={rowIndex}
                data-scroll-animate="fadeInRight"
                style={`animation-delay: ${rowIndex * 0.1}s;`}
              >
                <div class="git-content">
                  <div class="content-header">
                    <span class="commit-hash">{event.commit}</span>
                    <span class="commit-date">({event.date})</span>
                    <span
                      class="commit-ref"
                      style={`color: ${coloredBranch?.color}; border-color: ${coloredBranch?.color};`}
                    >
                      {coloredBranch?.label}
                    </span>
                  </div>
                  <div class="commit-message">
                    <h3 class="message-title" style={`color: ${coloredBranch?.color}`}>
                      {event.title}
                    </h3>
                    <p class="message-detail">{event.detail}</p>
                  </div>
                </div>
              </div>
            );
          })
        }
      </div>
    </git-timeline>
  </div>
</section>

<style lang="scss">
  .git-timeline-container {
    max-width: 900px;
    margin: 4rem auto;
    background-color: #0f172a;
    border-radius: 12px;
    border: 1px solid #1e293b;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, "Liberation Mono", monospace;
    overflow: hidden;
    color: #e2e8f0;

    .git-header {
      background-color: #0b0f19;
      padding: 1rem 1.5rem;
      border-bottom: 1px solid #1e293b;
      display: flex;
      align-items: center;
      gap: 1.5rem;

      .mac-buttons {
        display: flex;
        gap: 8px;
        span {
          width: 12px;
          height: 12px;
          border-radius: 50%;
          &:nth-child(1) {
            background-color: #f43f5e;
          }
          &:nth-child(2) {
            background-color: #f59e0b;
          }
          &:nth-child(3) {
            background-color: #10b981;
          }
        }
      }

      h2 {
        margin: 0;
        font-size: 0.95rem;
        font-weight: normal;
        color: #cbd5e1;

        .prompt {
          color: #06b6d4;
          font-weight: bold;
          margin-right: 8px;
        }
      }
    }
  }

  .git-canvas {
    padding: 2rem 1.5rem;
  }

  .git-legend {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    font-size: 0.85rem;
    padding: 0.5rem 1rem;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.05);

    .legend-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--b-color);
      font-weight: 600;
      letter-spacing: 0.5px;

      .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background-color: var(--b-color);
        box-shadow: 0 0 10px var(--b-color);
      }
    }
  }

  .git-graph-wrapper {
    display: flex;
    position: relative;
    margin-top: 1rem;
    gap: 1rem;

    .svg-container {
      width: 110px;
      flex-shrink: 0;
      position: relative;

      .git-svg {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        overflow: visible;
      }
    }

    .content-container {
      flex-grow: 1;
      display: flex;
      flex-direction: column;
    }
  }

  .git-row {
    position: relative;
    padding-bottom: 2.5rem;
    transition: background-color 0.2s ease;
    border-radius: 8px;
    padding-left: 10px;

    &:last-child {
      padding-bottom: 0;
    }
    &:hover {
      background-color: rgba(255, 255, 255, 0.03);
    }
  }

  .git-content {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: 0.5rem 1rem;
    margin-left: 0.5rem;
    z-index: 4;

    .content-header {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 0.5rem;
      flex-wrap: wrap;

      .commit-hash {
        color: #facc15;
        font-size: 0.9rem;
      }
      .commit-date {
        color: #94a3b8;
        font-size: 0.85rem;
      }

      .commit-ref {
        font-size: 0.7rem;
        padding: 2px 10px;
        border: 1px solid;
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.05);
        font-weight: bold;
        letter-spacing: 0.5px;
      }
    }

    .commit-message {
      .message-title {
        margin: 0 0 0.4rem 0;
        font-size: 1.15rem;
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
        font-weight: 600;
        letter-spacing: 0.3px;
      }
      .message-detail {
        margin: 0;
        color: #94a3b8;
        font-size: 0.95rem;
        line-height: 1.5;
        font-family:
          system-ui,
          -apple-system,
          sans-serif;
      }
    }
  }

  @media screen and (max-width: 600px) {
    .git-timeline-container {
      margin: 4rem 1rem;
    }
    .git-header h2 {
      font-size: 0.8rem !important;
    }
    .git-canvas {
      padding: 1rem;
    }
    .git-graph-wrapper .svg-container {
      width: 60px;
    }
  }

  .svg-container {
    transition: opacity 0.2s ease-in;
  }

  @keyframes graphWipeDown {
    0% {
      clip-path: inset(0 -50% 100% -50%);
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    100% {
      clip-path: inset(0 -50% -10% -50%);
      opacity: 1;
    }
  }

  :global(.animate__wipeDown) {
    animation-name: graphWipeDown !important;
    animation-duration: 2s !important;
    animation-timing-function: ease-in-out !important;
    animation-fill-mode: forwards !important;
  }
</style>

<script>
  class GitTimeline extends HTMLElement {
    resizeObserver: ResizeObserver;

    constructor() {
      super();
      this.resizeObserver = new ResizeObserver(() => this.draw());
    }

    connectedCallback() {
      this.resizeObserver.observe(this);
      setTimeout(() => this.draw(), 50);

      const svgContainer = this.querySelector(".svg-container") as HTMLElement;
      if (svgContainer) {
        const observer = new IntersectionObserver(
          (entries) => {
            if (entries[0].isIntersecting) {
              svgContainer.style.opacity = "1";
              svgContainer.classList.add("animate__animated", "animate__wipeDown");
              observer.disconnect();
            }
          },
          { rootMargin: "0px 0px -50% 0px", threshold: 0 },
        );
        observer.observe(this);
      }
    }

    disconnectedCallback() {
      this.resizeObserver.disconnect();
    }

    draw() {
      const dataStr = this.dataset.timeline;
      if (!dataStr) return;

      const { events, branches } = JSON.parse(dataStr);
      const svg = this.querySelector(".git-svg");
      const container = this.querySelector(".svg-container");

      if (!svg || !container) return;
      const containerRect = container.getBoundingClientRect();
      if (containerRect.height === 0 || containerRect.width === 0) return;

      const rows = Array.from(this.querySelectorAll(".git-row"));
      const colWidth = 20;
      const offsetLeft = 14;

      const nodeCoords = rows
        .map((row: any, i) => {
          const header = row.querySelector(".content-header");
          if (!header) return null;

          let nodeY = row.offsetTop + header.offsetTop + header.offsetHeight / 2;
          const branchIndex = branches.findIndex((b: any) => b.id === events[i].branch);
          const nodeX = offsetLeft + branchIndex * colWidth;

          return {
            x: nodeX,
            y: nodeY,
            color: events[i].coloredAs
              ? branches.find((b: any) => b.id === events[i].coloredAs).color
              : branches[branchIndex].color,
            branch: events[i].branch,
            track: events[i].track,
            idx: i,
          };
        })
        .filter(Boolean);

      let svgContent = "";

      const getTrackX = (trackId: string) => {
        const ev = events.find((e: any) => e.track === trackId);
        if (!ev) return offsetLeft;
        const bIdx = branches.findIndex((b: any) => b.id === ev.branch);
        return offsetLeft + bIdx * colWidth;
      };

      const tracks = Array.from(new Set(events.map((e: any) => e.track)));

      tracks.forEach((trackId: any) => {
        const bEvents = nodeCoords.filter((n: any) => n.track === trackId);
        if (bEvents.length === 0) return;

        const firstEvent = bEvents[0];
        const rawFirst = events[firstEvent!.idx];
        const b = branches.find((br: any) => br.id === firstEvent!.branch);

        for (let i = 0; i < bEvents.length - 1; i++) {
          const p1 = bEvents[i];
          const p2 = bEvents[i + 1];
          svgContent += `<path d="M ${p1!.x} ${p1!.y} L ${p2!.x} ${p2!.y}" fill="none" stroke="${b.color}" stroke-width="3" style="filter: drop-shadow(0 0 4px ${b.color}88);" />`;
        }

        if (trackId !== "life") {
          const parentTrackId = rawFirst.branchFromTrack || "life";
          const parentX = getTrackX(parentTrackId);

          const curveEndY = firstEvent!.y;
          const curveStartY = Math.max(0, curveEndY - 50);

          svgContent += `
            <path d="
              M ${parentX} ${curveStartY}
              C ${parentX} ${curveStartY + 25}, ${firstEvent!.x} ${curveEndY - 25}, ${firstEvent!.x} ${curveEndY}
            " fill="none" stroke="${b.color}" stroke-width="3" style="filter: drop-shadow(0 0 4px ${b.color}88);" />
          `;
        }

        const lastEvent = bEvents[bEvents.length - 1];
        const rawLast = events[lastEvent!.idx];

        if (!rawLast.trackOpen) {
          const targetTrackId = "life";
          const targetX = getTrackX(targetTrackId);

          let mergeY = lastEvent!.y + 50;

          if (rawLast.mergeBefore) {
            const targetNode = nodeCoords.find((n: any) => events[n.idx].commit === rawLast.mergeBefore);
            if (targetNode) {
              mergeY = targetNode.y - 25;
            }
          }

          const curveStartY = Math.max(lastEvent!.y, mergeY - 50);
          const cp1Y = curveStartY + (mergeY - curveStartY) / 2;
          const cp2Y = mergeY - (mergeY - curveStartY) / 2;

          svgContent += `
            <path d="
              M ${lastEvent!.x} ${lastEvent!.y}
              L ${lastEvent!.x} ${curveStartY}
              C ${lastEvent!.x} ${cp1Y}, ${targetX} ${cp2Y}, ${targetX} ${mergeY}
            " fill="none" stroke="${b.color}" stroke-width="3" opacity="0.6" style="filter: drop-shadow(0 0 4px ${b.color}88);" />
          `;
        } else {
          // UPDATE: Omit dash-array if the track is the main 'life' branch
          const strokeDashAttr = trackId === "life" ? "" : 'stroke-dasharray="6 6"';

          svgContent += `
            <path d="M ${lastEvent!.x} ${lastEvent!.y} L ${lastEvent!.x} ${containerRect.height + 40}"
                  fill="none" stroke="${b.color}" stroke-width="3" ${strokeDashAttr} opacity="0.8" style="filter: drop-shadow(0 0 4px ${b.color}88);" />
          `;
        }
      });

      nodeCoords.forEach((node: any) => {
        svgContent += `<line x1="${node.x + 8}" y1="${node.y}" x2="100%" y2="${node.y}"
                         stroke="${node.color}" stroke-width="2" opacity="0.2" stroke-dasharray="4 3"/>`;

        svgContent += `<circle cx="${node.x}" cy="${node.y}" r="8" fill="#0f172a" stroke="none" />`;

        svgContent += `<circle cx="${node.x}" cy="${node.y}" r="5" fill="#0f172a" stroke="${node.color}" stroke-width="3"
                         style="transition: all 0.2s ease; transform-origin: ${node.x}px ${node.y}px; filter: drop-shadow(0 0 8px ${node.color});"
                         onmouseover="this.setAttribute('r', '7')"
                         onmouseout="this.setAttribute('r', '5')" />`;
      });

      svg.innerHTML = svgContent;
    }
  }

  if (!customElements.get("git-timeline")) {
    customElements.define("git-timeline", GitTimeline);
  }
</script>
